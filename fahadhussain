        text-decoration: none;
        color: #cbd5e1;
        font-size: 0.875rem;
        font-weight: 500;
        transition: color 0.3s;
    }
    
    .nav-link::after {
        content: '';
        position: absolute;
        width: 0;
        height: 2px;
        bottom: -4px;
        left: 0;
        background: linear-gradient(90deg, var(--gold-500), var(--gold-400));
        transition: width 0.3s ease;
    }
    
    .nav-link:hover, .nav-link.active {
